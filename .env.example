# Development API base (dev server uses proxy to http://localhost:2030 by default)
VITE_API_BASE=/api

# Base URL of the backend API for production deployment.
# Leave blank to use Vite development proxy (http://localhost:2030) or relative paths.
# When deploying to Vercel, set this to your production backend URL (e.g. https://api.yourdomain.com).
VITE_API_URL=
